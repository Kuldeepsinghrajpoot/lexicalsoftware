# Resend API key (get one at https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=ayush741555@gmail.com

# Optional: inbox for job applications. If unset, falls back to
# CONTACT_TO_EMAIL.
CAREERS_TO_EMAIL=ayush741555@gmail.com

# Sender address. Until your domain is verified with Resend, this MUST stay
# on resend.dev, e.g. "Lexical Software <onboarding@resend.dev>".
# Once your domain is verified (see README), change to:
# CONTACT_FROM_EMAIL=Lexical Software <noreply@lexicalsoftware.dev>
CONTACT_FROM_EMAIL=Lexical Software <onboarding@resend.dev>

# Optional: secret used to sign the math captcha tokens. Set this to any
# random string in production so captcha tokens can't be guessed/replayed.
CAPTCHA_SECRET=change-me-to-a-random-string

# Cloudinary cloud name (find it in your Cloudinary dashboard). Once set,
# project/team/blog images referenced by cloudinaryId in src/data/*.ts will
# render via Cloudinary's CDN. Leave unset to show styled placeholders.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
